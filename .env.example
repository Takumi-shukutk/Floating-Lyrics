# Spotify API設定
# https://developer.spotify.com/ から取得してください
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# オプション: 他の歌詞APIキー
# https://www.musixmatch.com/settings/account で取得
MUSIXMATCH_API_KEY=

# https://genius.com/api-clients で取得
GENIUS_API_KEY=
